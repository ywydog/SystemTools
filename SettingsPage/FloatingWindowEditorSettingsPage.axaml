<ci:SettingsPageBase x:Class="SystemTools.FloatingWindowEditorSettingsPage"
                     xmlns="https://github.com/avaloniaui"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:ci="http://classisland.tech/schemas/xaml/core"
                     xmlns:controls="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
                     xmlns:controls1="clr-namespace:SystemTools.Controls"
                     mc:Ignorable="d"
                     d:DesignHeight="450"
                     d:DesignWidth="800">
    <ScrollViewer>
        <StackPanel Classes="settings-container animated-intro">
            <Label FontSize="20"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                SystemTools
            </Label>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <ci:FluentIcon FontSize="56"
                               Glyph="&#xEA36;"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                <Label VerticalAlignment="Center" FontSize="28">设置 · 悬浮窗</Label>
            </StackPanel>

            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xEA37;}"
                                       Header="显示悬浮窗">
                <controls:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding ViewModel.Settings.ShowFloatingWindow, Mode=TwoWay}"
                                  IsEnabled="{Binding ViewModel.HasFloatingTriggerEntries}"
                                  Click="OnFloatingWindowConfigChanged" />
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>

            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xE10B;}"
                                       Header="悬浮窗缩放"
                                       Description="调整悬浮窗缩放大小">
                <controls:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Slider Width="160"
                                Minimum="0.5"
                                Maximum="2"
                                TickFrequency="0.1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ViewModel.Settings.FloatingWindowScale, Mode=TwoWay}" />
                        <TextBlock Text="{Binding ViewModel.Settings.FloatingWindowScale, StringFormat='{}{0:F1}x'}"
                                   Width="46"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>

            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xF17E;}"
                                       Header="图标大小"
                                       Description="调整悬浮窗内图标缩放">
                <controls:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Slider Width="160"
                                Minimum="15"
                                Maximum="50"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ViewModel.Settings.FloatingWindowIconSize, Mode=TwoWay}" />
                        <TextBlock Text="{Binding ViewModel.Settings.FloatingWindowIconSize, StringFormat='{}{0}px'}"
                                   Width="46"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>

            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xF17E;}"
                                       Header="文字大小"
                                       Description="调整悬浮窗内文字缩放">
                <controls:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Slider Width="160"
                                Minimum="8"
                                Maximum="25"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ViewModel.Settings.FloatingWindowTextSize, Mode=TwoWay}" />
                        <TextBlock Text="{Binding ViewModel.Settings.FloatingWindowTextSize, StringFormat='{}{0}px'}"
                                   Width="46"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>

            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xF045;}"
                                       Header="透明度"
                                       Description="调整悬浮窗透明度">
                <controls:SettingsExpander.Footer>
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Slider Width="160"
                                Minimum="10"
                                Maximum="100"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding ViewModel.Settings.FloatingWindowOpacity, Mode=TwoWay}" />
                        <TextBlock Text="{Binding ViewModel.Settings.FloatingWindowOpacity, StringFormat='{}{0}%'}"
                                   Width="46"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </controls:SettingsExpander.Footer>
            </controls:SettingsExpander>


            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xEA2F;}"
                                       Header="悬浮窗层级"
                                       Description="置底会显示在大多数窗口后方，置顶会显示在大多数窗口前方。">
                <controls:SettingsExpander.Footer>
                    <ComboBox SelectedIndex="{Binding ViewModel.Settings.FloatingWindowLayer, Mode=TwoWay}">
                        <ComboBoxItem>
                            <ci:IconText Glyph="&#xE0CB;" Text="置底" />
                        </ComboBoxItem>
                        <ComboBoxItem>
                            <ci:IconText Glyph="&#xE197;" Text="置顶" />
                        </ComboBoxItem>
                    </ComboBox>
                </controls:SettingsExpander.Footer>
                <controls:SettingsExpanderItem IconSource="{ci:FluentIconSource &#xE125;}"
                                               Content="层级设置频率"
                                               Description="SystemTools 在什么时候重新设置悬浮窗层级。较高频率可能带来额外性能占用。">
                    <controls:SettingsExpanderItem.Footer>
                        <ComboBox SelectedIndex="{Binding ViewModel.Settings.FloatingWindowLayerRecheckMode, Mode=TwoWay}">
                            <ComboBoxItem>窗口层级变化时</ComboBoxItem>
                            <ComboBoxItem>前台窗口变化时</ComboBoxItem>
                            <ComboBoxItem>每 50ms</ComboBoxItem>
                            <ComboBoxItem>每 1ms</ComboBoxItem>
                        </ComboBox>
                    </controls:SettingsExpanderItem.Footer>
                </controls:SettingsExpanderItem>
            </controls:SettingsExpander>

            <controls:SettingsExpander IconSource="{ci:FluentIconSource &#xEA37;}"
                                       Header="悬浮窗按钮布局"
                                       Description="您可在下方通过拖拽调整行内按钮顺序，或添加行以实现纵列排布等功能"
                                       IsExpanded="True">
                <StackPanel Margin="12,8,12,12" Spacing="8">
                    <Grid>
                        <Button Content="添加行" Width="92" HorizontalAlignment="Left"
                                Click="OnAddFloatingTriggerRowClick" />
                    </Grid>
                    <ItemsControl ItemsSource="{Binding ViewModel.FloatingTriggerRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        Margin="0,0,0,6"
                                        DragDrop.AllowDrop="True"
                                        DragDrop.DragOver="OnFloatingTriggerRowDragOver"
                                        DragDrop.Drop="OnFloatingTriggerRowDrop">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                            <TextBlock Text="按钮行"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            <Button Grid.Column="1" Content="删除行"
                                                    Click="OnRemoveFloatingTriggerRowClick"
                                                    Theme="{StaticResource TransparentButton}" />
                                        </Grid>
                                        <Border MinHeight="52"
                                                CornerRadius="6"
                                                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                Padding="6">
                                            <ItemsControl ItemsSource="{Binding Buttons}"
                                                          HorizontalAlignment="Stretch"
                                                          VerticalAlignment="Center"
                                                          DragDrop.AllowDrop="True"
                                                          DragDrop.DragOver="OnFloatingTriggerRowDragOver"
                                                          DragDrop.Drop="OnFloatingTriggerRowDrop">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center" Spacing="14" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="0,0,2,0"
                                                            Tag="{Binding ButtonId}"
                                                            DragDrop.AllowDrop="True"
                                                            DragDrop.DragOver="OnFloatingTriggerItemDragOver"
                                                            DragDrop.Drop="OnFloatingTriggerItemDrop"
                                                            PointerPressed="OnFloatingTriggerItemPointerPressed"
                                                            PointerMoved="OnFloatingTriggerItemPointerMoved"
                                                            PointerReleased="OnFloatingTriggerItemPointerReleased">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="{Binding Icon}" />
                                                                <TextBlock Text="{Binding ButtonName}" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </controls:SettingsExpander>
        </StackPanel>
    </ScrollViewer>
</ci:SettingsPageBase>